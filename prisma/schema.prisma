// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id             String         @id @default(cuid())
  name           String
  location       String
  users          User[]
  matches        Match[]
  notices        Notice[]
  settings       Json?
  branchSettings BranchSetting?

  @@map("branches")
}

model User {
  id                String               @id @default(cuid())
  name              String
  email             String               @unique
  phone             String
  branchId          String               @map("branch_id")
  role              String               @default("player")
  experience        String?
  isProfileComplete Boolean              @default(false) @map("is_profile_complete")
  membershipStatus  String               @default("none") @map("membership_status")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  branch            Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  memberships       Membership[]
  attendances       Attendance[]
  matchParticipants MatchParticipant[]
  performances      Performance[]
  payments          Payment[]
  enquiries         Enquiry[]
  coachProfile      CoachProfile?
  coachingSessions  CoachingSession[]

  @@map("users")
}

model Membership {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  plan       String
  startDate  DateTime @map("start_date")
  expiryDate DateTime @map("expiry_date")
  status     String
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memberships")
}

model Match {
  id             String               @id @default(cuid())
  branchId       String               @map("branch_id")
  teams          String
  date           DateTime
  time           String
  venue          String
  fee            Int
  status         String
  result         String?
  createdAt      DateTime             @default(now()) @map("created_at")
  branch         Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  participants   MatchParticipant[]
  performances   Performance[]
  scoringSession Json?                @map("scoring_session")

  @@map("matches")
}

model MatchParticipant {
  id      String @id @default(cuid())
  matchId String @map("match_id")
  userId  String @map("user_id")
  status  String @default("Pending")
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("match_participants")
}

model Performance {
  id      String  @id @default(cuid())
  userId  String  @map("user_id")
  matchId String  @map("match_id")
  runs    Int     @default(0)
  wickets Int     @default(0)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@map("performances")
}

model Attendance {
  id      String   @id @default(cuid())
  userId  String   @map("user_id")
  date    DateTime
  status  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("attendances")
}

model Notice {
  id        String   @id @default(cuid())
  branchId  String   @map("branch_id")
  title     String
  message   String
  date      DateTime
  important Boolean
  createdAt DateTime @default(now()) @map("created_at")
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("notices")
}

// Now add all other models from in-memory db
model CoachProfile {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    CoachingSession[]
  attendances StaffAttendance[]

  @@map("coach_profiles")
}

model StaffAttendance {
  id        String   @id @default(cuid())
  coachId   String   @map("coach_id")
  date      DateTime
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@map("staff_attendances")
}

model CoachingSession {
  id        String   @id @default(cuid())
  coachId   String   @map("coach_id")
  userId    String   @map("user_id")
  date      DateTime
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  coach     CoachProfile @relation(fields: [coachId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coaching_sessions")
}

model Payment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  amount      Int
  method      String
  status      String
  date        DateTime
  remarks     String?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Enquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  message   String
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("enquiries")
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  price       Int
  durationDays Int @map("duration_days")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("plans")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model ShopItem {
  id          String   @id @default(cuid())
  name        String
  price       Int
  description String?
  imageUrl    String?  @map("image_url")
  stock       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("shop_items")
}

model BranchSetting {
  id        String   @id @default(cuid())
  branchId  String   @unique @map("branch_id")
  settings  Json
  updatedAt DateTime @updatedAt @map("updated_at")
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("branch_settings")
}
